{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "GregEditor Mac Development Build",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "command": "/Users/Shared/Epic Games/UE_5.7/Engine/Build/BatchFiles/Mac/Build.sh",
            "args": [
                "GregEditor",
                "Mac",
                "Development",
                "${workspaceFolder}/Greg.uproject",
                "-waitmutex"
            ],
            "problemMatcher": "$msCompile",
            "type": "shell"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang++ build active file",
            "command": "/usr/bin/clang++",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-isysroot",
                "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}